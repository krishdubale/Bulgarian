  "lessonTemplate": {
    "standardLessons": {
      "lessonIndices": [1, 2, 3, 4, 5, 6],
      "objective": {"functionTargets": 1, "grammarTargets": 1},
      "newLexicalSet": {"default": 6, "a1Early": 5, "a2b1Max": 8, "hardCap": 8},
      "coreModelSentences": {
        "total": 8,
        "newOnly": 4,
        "mixedOldNew": 4
      },
      "patternBlock": {
        "microPatterns": 2,
        "examplesPerPattern": 3
      },
      "controlledPractice": 6,
      "contextPracticeMiniDialogueTurns": 4,
      "cumulativeRecycle": {
        "items": 6,
        "minOldContentRatio": 0.7
      },
      "lessonCheck": {
        "items": 10,
        "balance": "old_new_balanced"
      }
    },
    "consolidationLesson": {
      "lessonIndex": 7,
      "newWords": 0,
      "newGrammar": 0,
      "policy": "all_recombination"
    },
    "checkpointLesson": {
      "lessonIndex": 8,
      "coverageCurrentUnitRatio": 0.6,
      "coveragePriorUnitsRatio": 0.4
    }
  },
  "vocabularySystem": {
    "newWordLoad": {
      "A1": {"min": 5, "max": 6},
      "A2": {"min": 6, "max": 7},
      "B1": {"min": 6, "max": 8}
    },
    "groupingLogic": [
      "Primary: communicative theme",
      "Secondary: frequency and usefulness",
      "Tertiary: combinability"
    ],
    "repetitionScheduling": {
      "introLessonAppearances": 2,
      "nextTwoLessonsAppearances": {"min": 1, "max": 2},
      "minSameUnitAppearances": 5,
      "minByNextThreeUnitsAppearances": 8,
      "mustReappearInNextThreeLessons": true
    },
    "beginnerCoreFirst80Categories": [
      "pronouns",
      "be/have/go/want/need/can",
      "yes/no/please/thanks/sorry",
      "numbers 1-20",
      "time basics",
      "people core",
      "places core",
      "food staples",
      "adjectives core",
      "question words"
    ],
    "difficultyScaling": {
      "A1": "concrete high-frequency low-morphology",
      "A2": "abstract everyday + service vocabulary",
      "B1": "opinion argument workplace media societal vocabulary"
    }
  },
  "grammarProgression": {
    "A1": [
      "Pronouns + to be + simple statements",
      "Basic questions + negation",
      "Noun number + core agreement",
      "Definiteness/article behavior",
      "Present tense high-frequency verbs",
      "Basic prepositions place/time",
      "Modals ability/necessity basic",
      "Imperative and polite requests",
      "Comparison intro",
      "Past/future intro minimal functional"
    ],
    "A2": [
      "Past system stabilization",
      "Future plans and intentions",
      "Pronoun/object handling expansion",
      "Aspect/action-completion contrasts",
      "Subordination basics because/when/if",
      "Comparison and quantity expansion",
      "Connected discourse sequencing/contrast"
    ],
    "B1": [
      "Clause combining and subordination depth",
      "Relative clauses",
      "Conditional patterns",
      "Reported/indirect speech basics",
      "Register shifts formal/informal",
      "Argument structures claim-reason-example"
    ]
  },
  "sentenceDesign": {
    "sentenceBankLines": {"min": 40, "max": 60},
    "compositionRatios": {
      "targetNewStructures": 0.4,
      "mixedOldNew": 0.4,
      "reviewHeavy": 0.2
    },
    "complexityRamp": {
      "A1": {"structure": "single-clause", "tokensMin": 4, "tokensMax": 8},
      "A2": {"structure": "coordinated clauses", "tokensMin": 7, "tokensMax": 12},
      "B1": {"structure": "subordinate/relative structures", "tokensMin": 10, "tokensMax": 18}
    },
    "reusePolicy": {
      "minTokenReuseFromOldContent": 0.5,
      "newGrammarMustAppearIn": [
        "isolated pattern sentence",
        "functional dialogue sentence",
        "mixed review sentence"
      ]
    }
  },
  "multiLanguageDesign": {
    "sharedSkeleton": {
      "unitMap": 36,
      "lessonCounts": "fixed",
      "lessonTemplate": "fixed",
      "recyclingAndScalingRules": "fixed"
    },
    "languageSpecificVariation": [
      "grammar sequence details per unit",
      "lexical lists and collocations",
      "sentence bank and morphology constraints"
    ],
    "adaptationPrinciple": "preserve communicative function, not literal one-to-one mapping"
  },
  "strictScalingRules": [
    {"id": 1, "rule": "Max new words", "value": "8 absolute cap per lesson"},
    {"id": 2, "rule": "Max new grammar", "value": "2 micro-targets per lesson"},
    {"id": 3, "rule": "Old-content floor", "value": "minimum 60% old material in practice after Unit 4"},
    {"id": 4, "rule": "Reappearance", "value": "every introduced word reappears in next 3 lessons"},
    {"id": 5, "rule": "Checkpoint recycle", "value": "40% prior-unit content"},
    {"id": 6, "rule": "No double novelty", "value": "avoid max grammar load + max vocab in same lesson"},
    {"id": 7, "rule": "Complexity cadence", "value": "every 2 units increase average sentence length by ~1 token"},
    {"id": 8, "rule": "Functional coverage", "value": "each unit includes at least 2 real-world dialogue contexts"},
    {"id": 9, "rule": "B1 discourse", "value": "every B1 lesson includes at least one multi-sentence response prompt"},
    {"id": 10, "rule": "Content retirement", "value": "no item retired before appearing in at least 3 separate unit contexts"}
  ]
}
